profiles {
    // Run this on-site: nextflow run main.nf -profile local
    local {
        process.conda = '/home/ec2-user/miniconda3/envs/bstools' 
    }

    // Run this on EC2: nextflow run main.nf -profile cloud
    cloud {
        docker.enabled = true
        process.container = 'biocontainers/samtools:v1.16.1_cv1' 
    }
}
