// This allows Nextflow to manage dependencies via Conda
conda.enabled = true

params {
    input_csv = "trial_samples.csv"
    outdir    = "results"
}

profiles {
    // Run on your ThinkPad: nextflow run main.nf -profile thinkpad
    thinkpad {
        // Use 'which bstools' on your laptop to find your local path
        process.conda = 'bstools' 
    }

    // Run on EC2: nextflow run main.nf -profile ec2
    ec2 {
        process.conda = '/home/ec2-user/miniconda3/envs/bstools' 
    }

    // Run on EC2 with Docker: nextflow run main.nf -profile cloud
    cloud {
        docker.enabled = true
        process.container = 'biocontainers/samtools:v1.16.1_cv1' 
    }
}
